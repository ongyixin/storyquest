# ─── MiniMax ────────────────────────────────────────────────────────────────
# Required for all LLM agent calls (StoryDirector, Writer, Continuity, ArtDirector, NPC)
MINIMAX_API_KEY=

# ─── Convex ─────────────────────────────────────────────────────────────────
# Run `npx convex dev` to get these after linking your project
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ─── Voice stack ─────────────────────────────────────────────────────────────
SPEECHMATICS_API_KEY=
VAPI_API_KEY=

# ─── Image generation ────────────────────────────────────────────────────────
IMAGE_MODEL_API_KEY=

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip all real API calls and return placeholder data.
# Useful for UI development and demos without spending API credits.
DEMO_MODE=true
